ALTBOT_DISCORD_TOKEN=put-your-discord-bot-token-here
ALTBOT_OWNER_ID=123456789012345678,987654321098765432

# Optional: timezone (business day boundary / market date)
ALTBOT_TIME_ZONE=Asia/Tokyo

# Optional: market model tuning
ALTBOT_MARKET_GBM_MU=0.00002
ALTBOT_MARKET_GBM_SIGMA=0.003
ALTBOT_MARKET_PASSIVE_MIN=0.996
ALTBOT_MARKET_PASSIVE_MAX=1.004
ALTBOT_MARKET_MEAN_REVERSION=0.18

# Optional: rate-limit tuning
ALTBOT_MIN_SAME_COMMAND_INTERVAL_MS=800
ALTBOT_SLASH_WINDOW_SECONDS=5
ALTBOT_MAX_SLASH_PER_WINDOW=8
ALTBOT_COMPONENT_WINDOW_SECONDS=4
ALTBOT_MAX_COMPONENT_PER_WINDOW=12
ALTBOT_CHART_MAX_CONCURRENT=2
